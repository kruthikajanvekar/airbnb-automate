# Airbnb Automate Configuration
# Copy this file to .env and fill in your values

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-string
# Avoid 6000 and other Chrome-blocked ports (ERR_UNSAFE_PORT in the browser)
FLASK_PORT=5000
FLASK_DEBUG=false

# Database
DATABASE_PATH=data/airbnb_automate.db

# Search URLs (structured flexible search matches Airbnb explore UI)
# AIRBNB_BASE_URL=https://www.airbnb.co.in
# FLEX_TRIP_MONTHS_COUNT=3

# Browser settings
HEADLESS=true

# Outreach login (Airbnb requires login for messaging)
# Default: persistent folder data/airbnb_browser_profile + optional data/browser_state.json backup.
# Run: pip install playwright && playwright install chrome
# Then set PLAYWRIGHT_CHANNEL=chrome (recommended for OAuth / real sites).
#
# PLAYWRIGHT_CHANNEL=chrome
# BROWSER_USER_DATA_DIR=data/airbnb_browser_profile

# Global rate limit (all searches / locations share one cap — sliding window)
# Default ≈ 40 messages / day if you treat the day as eight 3h windows × 5 sends
# OUTREACH_MAX_SENDS_PER_WINDOW=5
# OUTREACH_RATE_WINDOW_SECONDS=10800
# Pause between each attempt (spread bursts; default 120s)
# OUTREACH_INTER_MESSAGE_DELAY_SECONDS=120

# ─── Agent / LLM settings ───────────────────────────────────────────────
# Provider: openai | gemini | perplexity
LLM_PROVIDER=gemini
LLM_TEMPERATURE=0.7
#
# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
#
# Perplexity (OpenAI-compatible)
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_MODEL=sonar-pro
#
# Agent scheduler — how often the negotiation agent runs (hours, default 5)
AGENT_SCHEDULE_HOURS=5
